{
  "name": "managedcode.tps",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:tps",
    "build:tps": "tsc -p tsconfig.tps.json",
    "test": "npm run test:sdk",
    "test:sdk": "npm run test:typescript && npm run test:js",
    "test:typescript": "npm run test:types && npm run test:ts",
    "test:ts": "npm run build:tps && node --import tsx --test ../ts/tests/runtime/**/*.test.ts",
    "test:js": "npm run build:tps && node --test tests/node/**/*.test.mjs",
    "test:types": "tsc -p tsconfig.typecheck.json --noEmit",
    "coverage:js": "npm run build:tps && c8 --check-coverage --lines 90 --branches 90 --functions 90 --statements 90 node --test tests/node/**/*.test.mjs",
    "generate:example-snapshots": "npm run build:tps && node ../scripts/generate-example-snapshots.mjs",
    "sdk:matrix": "node ../scripts/runtime-matrix.mjs --compact",
    "sdk:coverage-matrix": "node ../scripts/runtime-matrix.mjs --coverage --compact"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "c8": "^10.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
