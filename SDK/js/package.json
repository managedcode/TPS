{
  "name": "managedcode-tps-javascript",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "scripts": {
    "build": "npm run build:tps",
    "build:tps": "tsc -p tsconfig.tps.json",
    "test": "npm run test:sdk",
    "test:sdk": "npm run test:types && npm run test:js",
    "test:js": "node --test tests/node/**/*.test.mjs",
    "test:types": "tsc -p tsconfig.typecheck.json --noEmit",
    "coverage:js": "c8 --check-coverage --lines 90 --branches 90 --functions 90 --statements 90 node --test tests/node/**/*.test.mjs",
    "sdk:matrix": "node ../scripts/runtime-matrix.mjs --compact",
    "sdk:coverage-matrix": "node ../scripts/runtime-matrix.mjs --coverage --compact"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "c8": "^10.1.3",
    "typescript": "^5.9.3"
  }
}
