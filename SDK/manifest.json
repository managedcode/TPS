{
  "version": 1,
  "docsRoot": "SDK/docs",
  "fixturesRoot": "SDK/fixtures",
  "runtimes": [
    {
      "id": "typescript",
      "language": "TypeScript",
      "path": "SDK/ts",
      "runner": "ubuntu-latest",
      "setup": "node",
      "enabled": true,
      "build": "npm --prefix SDK/js run build:tps",
      "test": "npm --prefix SDK/js run test:typescript",
      "coverage": "npm --prefix SDK/js run coverage:typescript"
    },
    {
      "id": "javascript",
      "language": "JavaScript",
      "path": "SDK/js",
      "runner": "ubuntu-latest",
      "setup": "node",
      "enabled": true,
      "build": "npm --prefix SDK/js run build:tps",
      "test": "npm --prefix SDK/js run test:js",
      "coverage": "npm --prefix SDK/js run coverage:js"
    },
    {
      "id": "dotnet",
      "language": "C#",
      "path": "SDK/dotnet",
      "runner": "ubuntu-latest",
      "setup": "dotnet",
      "enabled": true,
      "build": "dotnet build SDK/dotnet/ManagedCode.Tps.slnx -warnaserror --no-restore",
      "test": "dotnet test SDK/dotnet/ManagedCode.Tps.slnx --no-restore",
      "coverage": "dotnet test SDK/dotnet/ManagedCode.Tps.slnx --no-restore /p:CollectCoverage=true /p:CoverletOutputFormat=json /p:ThresholdType=line%2Cbranch%2Cmethod /p:Threshold=90"
    },
    {
      "id": "flutter",
      "language": "Flutter",
      "path": "SDK/flutter",
      "runner": "ubuntu-latest",
      "setup": "dart",
      "enabled": true,
      "build": "sh -c 'cd SDK/flutter && dart pub get && dart analyze'",
      "test": "sh -c 'cd SDK/flutter && dart pub get && dart test'",
      "coverage": "sh -c 'cd SDK/flutter && ./coverage.sh'"
    },
    {
      "id": "swift",
      "language": "Swift",
      "path": "SDK/swift",
      "runner": "macos-latest",
      "setup": "swift",
      "enabled": true,
      "build": "sh -c 'cd SDK/swift && swift build'",
      "test": "sh -c 'cd SDK/swift && swift test'",
      "coverage": "sh -c 'cd SDK/swift && ./coverage.sh'"
    },
    {
      "id": "java",
      "language": "Java",
      "path": "SDK/java",
      "runner": "ubuntu-latest",
      "setup": "java",
      "enabled": true,
      "build": "sh -c 'cd SDK/java && ./build.sh'",
      "test": "sh -c 'cd SDK/java && ./test.sh'",
      "coverage": "sh -c 'cd SDK/java && ./coverage.sh'"
    }
  ]
}
